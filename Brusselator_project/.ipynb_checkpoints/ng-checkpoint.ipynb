    "# here we compute our snapshots with customized FOMs\n",
    "\n",
    "import gc\n",
    "\n",
    "sample_mus = [2.75, 3.25, 3.75, 4.25]\n",
    "# instead of looping over these mu, compute snapshots for these 4 manually\n",
    "\n",
    "target_intervals = 64 \n",
    "\n",
    "#for mu in sample_mus:\n",
    "mu=4.25\n",
    "factor = 2\n",
    "internal_nt = target_intervals * factor    # so that newton converges, but we just take every /factor element into our snapshots\n",
    "        \n",
    "T_mu = parameter_study[mu]['period']        # to get the corresponding initial data and final time T from our list \n",
    "u0_raw_np = parameter_study[mu]['initial_data'].to_numpy().flatten()\n",
    "u0_mu = v_space.zeros(1)\n",
    "\n",
    "gfu_impl = u0_mu.vectors[0].real_part.impl\n",
    "gfu_impl.vec.FV().NumPy()[:] = u0_raw_np\n",
    "u0_single = u0_mu[0]\n",
    "\n",
    "print(f\"{mu} (T = {T_mu})...\")\n",
    "\n",
    "fom_mu = first_Brusselator_fom.with_(   # customized FOM\n",
    "    T=T_mu, \n",
    "    initial_data=u0_single, \n",
    "    time_stepper=ImplicitEulerTimeStepper(nt=internal_nt)\n",
    "    )\n",
    "    \n",
    "U = fom_mu.solve(mu)\n",
    "#U = U_fine[::factor]\n",
    "std_snapshots.append(U)\n",
    "\n",
    "#del U_fine\n",
    "del U\n",
    "gc.collect()\n",
    "\n",
    "len(std_snapshots)  # should be 260"
   ]
